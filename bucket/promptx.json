{
  "version": "0.2.16",
  "description": "Local-first encrypted prompt intelligence CLI for AI coding assistants",
  "homepage": "https://github.com/gautampachnanda101/prompt-detective",
  "license": "Proprietary",
  "architecture": {
    "64bit": {
      "url": "https://github.com/gautampachnanda101/homebrew-tap/releases/download/v0.2.16/promptx_Windows_x86_64.zip",
      "hash": "26d375c8c709d17b51a244283dd42fd75d796defa0fd95895ac0803b93eaf67f"
    }
  },
  "bin": "promptx.exe",
  "post_install": [
    "Write-Host ''",
    "Write-Host 'Promptx installed. Add your passkey to your shell profile:'",
    "Write-Host '  [System.Environment]::SetEnvironmentVariable(\"PROMPTX_PASSKEY\", \"your-passkey\", \"User\")'",
    "Write-Host 'Then run: promptx setup'",
    "Write-Host ''",
    "$vsix = \"$dir/promptx-vscode-0.2.16.vsix\"",
    "$installed = $false",
    "if (Test-Path $vsix) {",
    "    foreach ($editor in @('code','cursor','codium','code-insiders')) {",
    "        if (Get-Command $editor -ErrorAction SilentlyContinue) {",
    "            & $editor --install-extension $vsix --force",
    "            if ($LASTEXITCODE -eq 0) { $installed = $true }",
    "        }",
    "    }",
    "}",
    "if ($installed) {",
    "    Write-Host 'Promptx extension installed into detected VS Code-family editor(s).'",
    "} else {",
    "    Write-Host 'To install the Promptx extension manually:'",
    "    Write-Host \"  code --install-extension $vsix\"",
    "    Write-Host \"  cursor --install-extension $vsix\"",
    "    Write-Host \"  codium --install-extension $vsix\"",
    "}"
  ],
  "checkver": {
    "github": "https://github.com/gautampachnanda101/homebrew-tap"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/gautampachnanda101/homebrew-tap/releases/download/v$version/promptx_Windows_x86_64.zip"
      }
    }
  }
}
