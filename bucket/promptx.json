{
  "version": "0.1.0-rc60",
  "description": "Local-first encrypted prompt intelligence CLI for AI coding assistants",
  "homepage": "https://github.com/gautampachnanda101/prompt-detective",
  "license": "Proprietary",
  "architecture": {
    "64bit": {
      "url": "https://github.com/gautampachnanda101/homebrew-tap/releases/download/v0.1.0-rc60/promptx_Windows_x86_64.zip",
      "hash": "cd87efee9ef4ecb957d7c91b830091e00a32ba98f5102097abb86b87061f686c"
    }
  },
  "bin": "promptx.exe",
  "post_install": [
    "Write-Host ''",
    "Write-Host 'Promptx installed. Add your passkey to your shell profile:'",
    "Write-Host '  [System.Environment]::SetEnvironmentVariable(\"PROMPTX_PASSKEY\", \"your-passkey\", \"User\")'",
    "Write-Host 'Then run: promptx setup'",
    "Write-Host ''",
    "$vsix = \"$dir/promptx-vscode-0.1.0-rc60.vsix\"",
    "if ((Test-Path $vsix) -and (Get-Command code -ErrorAction SilentlyContinue)) {",
    "    code --install-extension $vsix",
    "    Write-Host 'Promptx VS Code extension installed.'",
    "} else {",
    "    Write-Host 'To install the Promptx VS Code extension:'",
    "    Write-Host \"  code --install-extension $vsix\"",
    "}"
  ],
  "checkver": {
    "github": "https://github.com/gautampachnanda101/homebrew-tap"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/gautampachnanda101/homebrew-tap/releases/download/v$version/promptx_Windows_x86_64.zip"
      }
    }
  }
}
